{
  "name": "mood-player-widget",
  "version": "1.0.0",
  "description": "Aesthetic floating desktop cassette player",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "package": "electron-packager . 'Mood Player' --platform=darwin --arch=x64 --overwrite --protocol=moodplayer --protocol-name='Mood Player'"
  },
  "dependencies": {
    "electron": "^29.1.0"
  },
  "devDependencies": {
    "electron-packager": "^17.1.2"
  }
}
